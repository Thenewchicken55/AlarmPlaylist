# YouTube Data API (optional — for importing YouTube playlists)
# Get credentials: https://console.cloud.google.com/apis/credentials
VITE_YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com

# Spotify Web API (optional — for importing Spotify playlists)
# Get credentials: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
